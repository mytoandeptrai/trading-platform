# Application
NODE_ENV=development
PORT=3001
APP_NAME=Trading Engine API

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=trading
DB_PASSWORD=trading_dev
DB_NAME=tradingengine
DB_SCHEMA=public

# Database SSL (for Aiven, Render, etc.)
DB_SSL_ENABLED=false
# DB_SSL_CA_PATH=ca-certificate.crt

# Redis
# Option 1: Use REDIS_URL (Upstash, Render, etc.) - takes priority
# REDIS_URL=rediss://default:PASSWORD@HOST:6379

# Option 2: Individual config (local development) - used if REDIS_URL is not set
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=trading_redis_pass
REDIS_DB=0

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production-min-256-bits
JWT_EXPIRATION=86400
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production
JWT_REFRESH_EXPIRATION=604800

# BullMQ (now uses REDIS_URL from Redis config above)
# BULLMQ_REDIS_HOST=localhost
# BULLMQ_REDIS_PORT=6379
# BULLMQ_REDIS_PASSWORD=trading_redis_pass

# Logging
LOG_LEVEL=debug
LOG_DIR=logs

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# Rate Limiting
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100

# Trading Configuration
DEFAULT_TAKER_FEE=0.001
DEFAULT_MAKER_FEE=0.0005
MIN_ORDER_AMOUNT=0.001
MAX_ORDER_AMOUNT=1000

# Email Configuration (Mailpit for development)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@tradingengine.local
SMTP_FROM_NAME=Trading Engine
MAILPIT_WEB_UI=http://localhost:8025
